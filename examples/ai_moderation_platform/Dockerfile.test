FROM python:3.14-slim AS base

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libsqlite3-dev \
    curl \
    git \
    gnupg2 \
    apt-transport-https \
    && curl -sSL https://packages.microsoft.com/keys/microsoft.asc | tee /etc/apt/trusted.gpg.d/microsoft.asc \
    && echo "deb [arch=amd64,arm64 signed-by=/etc/apt/trusted.gpg.d/microsoft.asc] https://packages.microsoft.com/debian/12/prod bookworm main" > /etc/apt/sources.list.d/mssql-release.list \
    && apt-get update \
    && ACCEPT_EULA=Y apt-get install -y --no-install-recommends msodbcsql18 unixodbc-dev \
    && rm -rf /var/lib/apt/lists/*

COPY dist/openviper-0.1.1-py3-none-any.whl /tmp/openviper-0.1.1-py3-none-any.whl
ARG OPENVIPER_EXTRAS="mariadb,tasks-redis,ai"
RUN pip install --no-cache-dir "/tmp/openviper-0.1.1-py3-none-any.whl[${OPENVIPER_EXTRAS}]" \
    && rm -f /tmp/openviper-0.1.1-py3-none-any.whl

COPY examples/ai_moderation_platform/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY examples/ai_moderation_platform/ /app/

ENV OPENVIPER_SETTINGS_MODULE=ai_moderation_platform.settings
